      "POST /rollback/snapshot": {
        "description": "Create snapshot",
        "parameters": {
          "description": "string - Snapshot description",
          "tags": "array - Tags for organization"
        },
        "request_body": {
          "description": "Before major refactor",
          "tags": ["pre-refactor", "stable"]
        },
        "response": {
          "success": "boolean",
          "snapshot_id": "uuid",
          "created_at": "ISO8601 string"
        },
        "example_curl": "curl -X POST https://your-domain.com/api/rollback/snapshot -H 'Content-Type: application/json' -d '{\"description\": \"Manual snapshot\", \"tags\": [\"stable\"]}'"
