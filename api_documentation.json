{
  "title": "Autonomous Cognitive Control Fabric - API Documentation",
  "version": "1.0.0",
  "base_url": "/api",
  "last_updated": "2026-03-01",
  "description": "Complete API reference for the ACCF meta-layer control system",
  "authentication": {
    "type": "none",
    "note": "In production, implement JWT or API key authentication"
  },
  "endpoints": {
    "health": {
      "GET /health": {
        "description": "System health check",
        "parameters": {},
        "response": {
          "status": "string",
          "components": {
            "control_kernel": "string",
            "cognitive_engine": "string",
            "state_graph": "string",
            "shadow_world": "string",
            "rollback_manager": "string"
          }
        },
        "example_curl": "curl -X GET https://your-domain.com/api/health"
      }
    },
    "control_kernel": {
      "GET /control-kernel/status": {
        "description": "Get Control Kernel status and current autonomy level",
        "parameters": {},
        "response": {
          "version": "string",
          "status": "string",
          "autonomy_level": "string (A0-A4)",
          "safety_policies": "object",
          "execution_log_size": "number"
        },
        "example_curl": "curl -X GET https://your-domain.com/api/control-kernel/status"
      },
      "POST /control-kernel/autonomy-level": {
        "description": "Set autonomy level (A0-A4)",
        "parameters": {
          "level": "string (required) - One of: A0, A1, A2, A3, A4"
        },
        "request_body": {
          "level": "A3"
        },
        "response": {
          "success": "boolean",
          "old_level": "string",
          "new_level": "string",
          "timestamp": "ISO8601 string"
        },
        "example_curl": "curl -X POST https://your-domain.com/api/control-kernel/autonomy-level -H 'Content-Type: application/json' -d '{\"level\": \"A3\"}'"
      },
      "POST /control-kernel/validate": {
        "description": "Validate operation against safety policies",
        "parameters": {
          "type": "string (required) - Operation type",
          "scope": "string - local or global",
          "description": "string - Operation description"
        },
        "request_body": {
          "type": "code_modification",
          "scope": "local",
          "description": "Refactor authentication module"
        },
        "response": {
          "valid": "boolean",
          "operation_id": "uuid",
          "requires_approval": "boolean",
          "requires_simulation": "boolean",
          "estimated_risk": "string (low|medium|high)"
        },
        "example_curl": "curl -X POST https://your-domain.com/api/control-kernel/validate -H 'Content-Type: application/json' -d '{\"type\": \"code_modification\", \"scope\": \"local\"}'"
      },
      "GET /control-kernel/execution-log": {
        "description": "Get execution log",
        "parameters": {
          "limit": "number (optional) - Number of entries to return (default: 50)"
        },
        "response": {
          "log": "array of log entries",
          "total": "number"
        },
        "example_curl": "curl -X GET 'https://your-domain.com/api/control-kernel/execution-log?limit=20'"
      }
    },
    "cognitive_engine": {
      "GET /cognitive-engine/status": {
        "description": "Get Cognitive Engine status and performance metrics",
        "parameters": {},
        "response": {
          "version": "string",
          "status": "string",
          "performance_metrics": {
            "avg_response_time_ms": "number",
            "total_queries": "number",
            "successful_queries": "number"
          },
          "meets_sla": "boolean"
        },
        "example_curl": "curl -X GET https://your-domain.com/api/cognitive-engine/status"
      },
      "POST /cognitive-engine/reason": {
        "description": "Perform fast reasoning (<2s)",
        "parameters": {
          "id": "string (optional) - Query ID",
          "type": "string (required) - Query type",
          "data": "object - Query data"
        },
        "request_body": {
          "type": "project_analysis",
          "data": {
            "project_id": "abc123"
          }
        },
        "response": {
          "success": "boolean",
          "query_id": "uuid",
          "result": "object",
          "elapsed_ms": "number",
          "timestamp": "ISO8601 string"
        },
        "example_curl": "curl -X POST https://your-domain.com/api/cognitive-engine/reason -H 'Content-Type: application/json' -d '{\"type\": \"project_analysis\", \"data\": {}}'"
      },
      "POST /cognitive-engine/self-improve": {
        "description": "Trigger self-improvement",
        "parameters": {
          "type": "string - Improvement type",
          "feedback": "object - Feedback data"
        },
        "request_body": {
          "type": "performance",
          "feedback": {
            "metric": "response_time",
            "suggestion": "cache_optimization"
          }
        },
        "response": {
          "success": "boolean",
          "improvement_type": "string",
          "status": "string"
        },
        "example_curl": "curl -X POST https://your-domain.com/api/cognitive-engine/self-improve -H 'Content-Type: application/json' -d '{\"type\": \"performance\"}'"
      },
      "GET /cognitive-engine/metrics": {
        "description": "Get performance metrics",
        "parameters": {},
        "response": {
          "avg_response_time_ms": "number",
          "total_queries": "number",
          "successful_queries": "number"
        },
        "example_curl": "curl -X GET https://your-domain.com/api/cognitive-engine/metrics"
      }
    },
    "state_graph": {
      "POST /state-graph/query": {
        "description": "Query state graph",
        "parameters": {
          "type": "string (required) - Query type: full, node, neighbors, path",
          "node_id": "string (optional) - Node ID for node/neighbors queries",
          "source": "string (optional) - Source node for path query",
          "target": "string (optional) - Target node for path query"
        },
        "request_body": {
          "type": "neighbors",
          "node_id": "control_kernel"
        },
        "response": {
          "success": "boolean",
          "result": "object or array",
          "elapsed_ms": "number"
        },
        "example_curl": "curl -X POST https://your-domain.com/api/state-graph/query -H 'Content-Type: application/json' -d '{\"type\": \"full\"}'"
      },
      "GET /state-graph/full": {
        "description": "Get full graph for visualization",
        "parameters": {},
        "response": {
          "nodes": "array of nodes",
          "links": "array of links",
          "metadata": "object",
          "stats": "object"
        },
        "example_curl": "curl -X GET https://your-domain.com/api/state-graph/full"
      },
      "GET /state-graph/stats": {
        "description": "Get graph statistics",
        "parameters": {},
        "response": {
          "node_count": "number",
          "edge_count": "number",
          "density": "number",
          "is_connected": "boolean"
        },
        "example_curl": "curl -X GET https://your-domain.com/api/state-graph/stats"
      },
      "GET /state-graph/node/{node_id}": {
        "description": "Get specific node data",
        "parameters": {
          "node_id": "string (required) - Node identifier"
        },
        "response": {
          "id": "string",
          "type": "string",
          "label": "string",
          "status": "string"
        },
        "example_curl": "curl -X GET https://your-domain.com/api/state-graph/node/control_kernel"
      }
    },
    "shadow_world": {
